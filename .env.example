# RECOMMENDED: Use a 'Reusable', 'Ephemeral', and 'Pre-authorized' key
TAILSCALE_AUTHKEY=tskey-auth-kXyZ1234567890-abcdefghij

# The name that will appear in your Tailscale machine list
TAILSCALE_HOSTNAME=tailscale-app

# Crucial for using Railway as a VPN (Exit Node)
TAILSCALE_ADDITIONAL_ARGS="--advertise-exit-node"

# Matches the version in your Dockerfile
TAILSCALE_VERSION=latest