# REQUIRED. Generate at https://login.tailscale.com/admin/settings/keys
# Recommended: a 'Reusable', 'Ephemeral', and 'Pre-authorized' key.
TAILSCALE_AUTHKEY=tskey-auth-kXyZ1234567890-abcdefghij

# Name shown in your Tailscale admin machine list.
TAILSCALE_HOSTNAME=tailscale-app

# Extra flags passed to `tailscale up`. Defaults to advertising an exit node.
# Set to an empty value to disable exit-node mode.
TAILSCALE_ADDITIONAL_ARGS=--advertise-exit-node

# Tailscale version baked into the image (build-time only).
# Must match an existing release at https://pkgs.tailscale.com/stable/
TAILSCALE_VERSION=1.98.4
